// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// User model with authentication and role-based access
model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String // Hashed with bcrypt
  firstName String
  lastName  String
  role      UserRole @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Relations - add your entity relations here
  items Item[]

  @@map("users")
}

enum UserRole {
  ADMIN
  ATTENDANT
  USER
}

// Example CRUD entity - use this as a template for your exam entities
model Item {
  id          String    @id @default(uuid())
  name        String
  description String?
  quantity    Int       @default(0)
  price       Float     @default(0)
  category    String?
  isActive    Boolean   @default(true)
  createdById String
  createdBy   User      @relation(fields: [createdById], references: [id])
  tags        ItemTag[] // Many-to-many relation
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime? // Soft delete field

  @@map("items")
}

// Example: Many-to-many relationship (Tags)
model Tag {
  id    String    @id @default(uuid())
  name  String    @unique
  items ItemTag[]

  @@map("tags")
}

model ItemTag {
  itemId String
  tagId  String
  item   Item   @relation(fields: [itemId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([itemId, tagId])
  @@map("item_tags")
}

