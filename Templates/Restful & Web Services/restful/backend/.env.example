# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ne_exam_db?schema=public"

# JWT Configuration
JWT_SECRET="your-super-secret-jwt-key-change-in-production-min-32-chars"
JWT_EXPIRES_IN="1h"
JWT_REFRESH_SECRET="your-refresh-token-secret-change-in-production"
JWT_REFRESH_EXPIRES_IN="7d"

# Server
PORT=3001
NODE_ENV=development

# CORS
CORS_ORIGIN="http://localhost:3000"

# Email (SMTP) - for development use https://ethereal.email
SMTP_HOST="smtp.ethereal.email"
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER="your-ethereal-user@ethereal.email"
SMTP_PASS="your-ethereal-password"
SMTP_FROM='"NE Exam App" <noreply@exam.com>'

# Frontend URL (used in email links)
FRONTEND_URL="http://localhost:3000"
